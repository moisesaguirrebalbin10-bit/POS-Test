APP_NAME="POS Chifa"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

LOG_CHANNEL=stack

# Despliegue SaaS multi-tenant (servidor/nube): PostgreSQL
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=servimax
DB_USERNAME=postgres
DB_PASSWORD=

# Aplicativo de escritorio (Electron, una empresa por instalacion local): SQLite
# DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite

SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync
SANCTUM_STATEFUL_DOMAINS=127.0.0.1:4200,localhost:4200
FRONTEND_URL=http://127.0.0.1:4200

# WebSockets en tiempo real (solo version web/SaaS): php artisan reverb:start --port=8090
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=127.0.0.1
REVERB_PORT=8090
REVERB_SCHEME=http

