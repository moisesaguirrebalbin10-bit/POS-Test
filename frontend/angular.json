{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "projects": {
    "pos-chifa": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/pos-chifa",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "tsconfig.app.json",
            "styles": ["src/styles.css"],
            "assets": ["src/assets"],
            "allowedCommonJsDependencies": ["html2canvas", "canvg", "raf", "rgbcolor", "core-js", "pusher-js"]
          },
          "configurations": {
            "production": { "optimization": true, "extractLicenses": true, "sourceMap": false }
          }
        },
        "serve": { "builder": "@angular-devkit/build-angular:dev-server", "options": { "buildTarget": "pos-chifa:build" } }
      }
    }
  }
}


